# Ejemplo de variables para el stack Docker.
# Copia este archivo a `.env.docker` (que SÍ está en .gitignore) y ajusta.
#
# Estas variables NO las lee automáticamente `docker compose` — están
# hard-codeadas dentro de `docker-compose.yml` para evitar drift. Sirven
# como documentación de qué credenciales quedan en el contenedor.

POSTGRES_USER=pokescan
POSTGRES_PASSWORD=pokescan_dev
POSTGRES_DB=pokemoncardpokedex

# DATABASE_URL: ESTA variable la consume la app Next.js (no Docker).
# Por eso la vas a querer copiar a `.env.local`, no a `.env.docker`. Con
# ella la página /docker-status puede conectarse al contenedor y probar
# que la BD dockerizada responde desde la app web.
#
# Desde tu máquina host:
DATABASE_URL=postgres://pokescan:pokescan_dev@localhost:5433/pokemoncardpokedex

# Desde otro contenedor del mismo compose (servicio `app`):
# DATABASE_URL=postgres://pokescan:pokescan_dev@db:5432/pokemoncardpokedex

# pgAdmin (opcional, levantar con el stack por defecto)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
